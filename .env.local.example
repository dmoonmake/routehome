# ─── Duffel API Token ─────────────────────────────────────────────────────
# Get your free token at: https://app.duffel.com/account/access-tokens
# → Sign up → Developers → Access tokens → Create token
#
# ⚠️  REQUIRED PERMISSIONS (check these when creating the token):
#     ✅ Air - Offer Requests (Read & Write)
#     ✅ Air - Offers (Read)
#     ✅ Air - Seat Maps (Read)
#
# Test tokens start with:  duffel_test_...  (sandbox data, free forever)
# Live tokens start with:  duffel_live_...  (real inventory, requires approval)

DUFFEL_TOKEN=your_token_here
